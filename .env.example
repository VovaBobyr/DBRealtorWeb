# Copy this to .env and fill in values

# PostgreSQL — must match the scraper's .env
POSTGRES_USER=sreality
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sreality
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Async DSN used by the FastAPI backend
DATABASE_URL=postgresql+asyncpg://sreality:changeme@db:5432/sreality
